{
  "manifest_version": 3,
  "name": "Nexa Download Manager Integration",
  "version": "0.1.0",
  "description": "Hands downloads and media streams off to the Nexa desktop app for fast multi-connection downloading.",
  "minimum_chrome_version": "102",
  "permissions": [
    "downloads",
    "cookies",
    "contextMenus",
    "webRequest",
    "storage",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Nexa Download Manager",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
